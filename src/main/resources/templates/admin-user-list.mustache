{{<layout}}
    {{$title}}{{model.title}}{{/title}}
    {{$body}}
        <h2>{{model.title}}</h2>
        <table>
            <thead>
            <tr>
                <th>이메일</th>
                <th>닉네임</th>
                <th>가입일</th>
                <th>정보 수정일</th>
                <th>최근 접속일</th>
                <th>OAuth 제공자</th>
                <th>자기소개</th>
                <th>타입</th>
            </tr>
            </thead>
            <tbody>
            {{#model.users}}
                <tr>
                    <td>{{email}}</td>
                    <td>{{nickname}}</td>
                    <td>{{createdAt}}</td>
                    <td>{{updatedAt}}</td>
                    <td>{{lastLoginAt}}</td>
                    <td>{{provider}}</td>
                    <td>{{bio}}</td>
                    <td>{{type}}</td>
                </tr>
            {{/model.users}}
            {{^model.users}}
                <tr>
                    <td colspan="8">데이터가 없습니다.</td>
                </tr>
            {{/model.users}}
            </tbody>
        </table>
    {{/body}}
{{/layout}}
