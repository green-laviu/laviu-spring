{{<layout}}
    {{$title}}{{model.title}}{{/title}}
    {{$body}}
        <h2>{{model.title}}</h2>
        <table>
            <thead>
            <tr>
                <th>신고자 id</th>
                <th>신고된 방송 id</th>
                <th>신고된 스트리머 id</th>
                <th>신고된 방송제목</th>
                <th>신고된 스트리머 닉네임</th>
                <th>상세사유</th>
                <th>신고유형</th>
                <th>방송시간</th>
                <th>처리신청 시간</th>
                <th>처리확인</th>
            </tr>
            </thead>
            <tbody>
            {{#model.reports}}
                <tr>
                    <td>{{reporterId}}</td>
                    <td>{{reportedBroadcastId}}</td>
                    <td>{{reportedStreamerId}}</td>
                    <td>{{broadcastTitle}}</td>
                    <td>{{streamerNickname}}</td>
                    <td>{{detailReason}}</td>
                    <td>{{reportType}}</td>
                    <td>{{broadcastTime}}</td>
                    <td>{{requestTime}}</td>
                    <td>
                        <button class="action-btn">버튼</button>
                    </td>
                </tr>
            {{/model.reports}}
            {{^model.reports}}
                <tr>
                    <td colspan="10">데이터가 없습니다.</td>
                </tr>
            {{/model.reports}}
            </tbody>
        </table>
    {{/body}}
{{/layout}}
