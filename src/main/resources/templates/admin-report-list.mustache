{{<layout}}
    {{$title}}신고 내역{{/title}}
    {{$body}}
        <h2>신고 내역</h2>
        <table>
            <thead>
            <tr>
                <th>신고자 id</th>
                <th>신고된 방송 id</th>
                <th>신고된 스트리머 id</th>
                <th>신고된 방송제목</th>
                <th>신고된 스트리머 닉네임</th>
                <th>상세 사유</th>
                <th>신고 유형</th>
                <th>접수 시간</th>
                <th>처리된 시간</th>
                <th>수락</th>
                <th>거절</th>
            </tr>
            </thead>
            <tbody>
            {{#model.reports}}
                <tr>
                    <td>{{reporterId}}</td>
                    <td>{{reportedStreamId}}</td>
                    <td>{{reportedStreamerId}}</td>
                    <td>{{broadcastTitle}}</td>
                    <td>{{streamerNickname}}</td>
                    <td>{{detailReason}}</td>
                    <td>{{category}}</td>
                    <td>{{createdAt}}</td>
                    <td>{{processedAt}}</td>
                    <td>
                        <button class="accept-btn" data-report-id="{{id}}">수락</button>
                    </td>
                    <td>
                        <button class="reject-btn" data-report-id="{{id}}">거절</button>
                    </td>
                </tr>
            {{/model.reports}}
            {{^model.reports}}
                <tr>
                    <td colspan="11">데이터가 없습니다.</td>
                </tr>
            {{/model.reports}}
            </tbody>
        </table>
    {{/body}}
{{/layout}}
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // 수락 버튼 클릭 이벤트
        document.querySelectorAll('.accept-btn').forEach(button => {
            button.addEventListener('click', function () {
                const reportId = this.getAttribute('data-report-id');
                // 백엔드 API 호출 (수락)
                updateReportStatus(reportId, 'RESOLVED');
            });
        });

        // 거절 버튼 클릭 이벤트
        document.querySelectorAll('.reject-btn').forEach(button => {
            button.addEventListener('click', function () {
                const reportId = this.getAttribute('data-report-id');
                // 백엔드 API 호출 (거절)
                updateReportStatus(reportId, 'REJECTED');
            });
        });

        async function updateReportStatus(reportId, status) {
            try {
                const response = await fetch(`/s/v1/admin/abusereports/${reportId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({status: status})
                });

                if (response.ok) {
                    alert('성공적으로 처리되었습니다.');
                    window.location.reload(); // 페이지 새로고침
                } else {
                    const error = await response.json();
                    alert(`처리 실패: ${error.message}`);
                }
            } catch (error) {
                console.error('API 호출 중 오류 발생:', error);
                alert('요청 중 오류가 발생했습니다.');
            }
        }
    });
</script>